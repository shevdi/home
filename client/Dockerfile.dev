FROM node:22-alpine

ARG BACKEND_URL=http://localhost:3001/api/v1
WORKDIR /app

# Root package files for workspace resolution
COPY package.json package-lock.json ./
COPY shared ./shared
COPY client ./client

RUN npm install

# Flatten: client runs from /app (watch sync target)
RUN cp -r client/. .

EXPOSE 3000
EXPOSE 8080

CMD ["npm", "run", "dev"]
