# syntax=docker/dockerfile:1
FROM node:22

WORKDIR /app

# Root package files for workspace resolution
COPY package.json package-lock.json ./
COPY shared ./shared
COPY server ./server

RUN --mount=type=cache,target=/root/.npm \
    npm install --no-audit --no-fund --fetch-retries=5 --fetch-retry-mintimeout=20000

# Flatten: server runs from /app (watch sync target). Symlink ../../shared = ./shared
RUN cp -r server/node_modules . && cp server/package*.json . && cp -r server/src . && cp server/tsconfig.json . 2>/dev/null || true

CMD ["npm", "run", "dev"]
