# Server Configuration
NODE_ENV=development
PORT=3000

# JWT signing (required — server exits if missing)
ACCESS_TOKEN_SECRET=generate-a-long-random-hex-string
REFRESH_TOKEN_SECRET=generate-another-long-random-hex-string

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
DB_NAME=shevdi_home

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# API Configuration
API_VERSION=v1

# DaData (optional, for reverse geocoding in Russia)
DADATA_API_KEY=your_api_key

# Logging
LOG_LEVEL=info

# Telegram Login Widget (optional — omit to disable; POST /auth/telegram/* returns 503)
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# TELEGRAM_PENDING_SECRET=long-random-secret-for-pending-registration-jwt
# TELEGRAM_AUTH_MAX_AGE_SECONDS=600