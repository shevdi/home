{
  "name": "shevdi-home",
  "version": "0.0.0",
  "description": "shevdi home",
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "mock-server",
    "e2e",
    "shared"
  ],
  "scripts": {
    "build": "npm run build --prefix client",
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "start": "concurrently \"npm run start --prefix server\" \"npm run start --prefix client\"",
    "typecheck": "npm run typecheck --prefix client",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "docker:build": "docker compose build",
    "docker:up:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:up": "docker compose -f docker-compose.dev.yml up --build",
    "docker:down": "docker compose down",
    "e2e": "npm run test --prefix e2e",
    "e2e:debug": "npm run test:debug --prefix e2e",
    "e2e:headed": "npm run test:headed --prefix e2e",
    "docker:up:e2e": "docker compose -f docker-compose.e2e.yml up --build",
    "e2e:mock": "docker compose -f docker-compose.e2e.yml up --build -d && npm run e2e",
    "e2e:report": "docker compose -f docker-compose.e2e.yml up --build -d && npm run e2e && npm run test:report --prefix e2e && npm run report:open --prefix e2e"
  },
  "keywords": [
    "nodejs",
    "express",
    "docker",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "concurrently": "^9.2.0",
    "dotenv-webpack": "^8.1.1",
    "nodemon": "^3.0.2",
    "typescript": "^5.8.3",
    "webpack": "^5.101.0"
  },
  "dependencies": {
    "fs-extra": "^11.3.2",
    "zod": "^4.3.6"
  }
}
