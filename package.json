{
  "name": "shevdi-home",
  "version": "0.1.0",
  "description": "shevdi home",
  "packageManager": "npm@11.4.2",
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "mock-server",
    "e2e",
    "shared",
    "ui-kit"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:ui-kit": "npm run build --workspace=@shevdi-home/ui-kit",
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:client": "concurrently -n ui-kit,client -c cyan,magenta \"npm run build:watch --workspace=@shevdi-home/ui-kit\" \"npm run dev --prefix client\"",
    "start": "concurrently \"npm run start --prefix server\" \"npm run start --prefix client\"",
    "typecheck": "npm run typecheck --prefix client",
    "lint": "npm run lint --workspaces --if-present",
    "docker:build": "docker compose build",
    "docker:up:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:watch:dev": "docker compose -f docker-compose.dev.yml watch",
    "docker:up": "docker compose -f docker-compose.dev.yml up --build",
    "docker:down": "docker compose down",
    "e2e": "npm run test --prefix e2e",
    "e2e:debug": "npm run test:debug --prefix e2e",
    "e2e:headed": "npm run test:headed --prefix e2e",
    "docker:up:e2e": "docker compose -f docker-compose.e2e.yml up --build",
    "docker:e2e": "docker compose -f docker-compose.e2e.yml --profile test up --build --exit-code-from e2e",
    "docker:e2e:down": "docker compose -f docker-compose.e2e.yml down -v",
    "docker:e2e:report": "docker compose -f docker-compose.e2e.yml --profile test up --build --exit-code-from e2e && npm run test:report --prefix e2e && npm run report:open --prefix e2e"
  },
  "keywords": [
    "nodejs",
    "express",
    "docker",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "concurrently": "^9.2.0",
    "dotenv-webpack": "^8.1.1",
    "nodemon": "^3.0.2",
    "turbo": "^2.8.20",
    "typescript": "^5.8.3",
    "webpack": "^5.101.0"
  },
  "dependencies": {
    "fs-extra": "^11.3.2",
    "zod": "^4.3.6"
  }
}
