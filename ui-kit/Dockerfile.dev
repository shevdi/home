FROM node:22-alpine

WORKDIR /app

# Manifests only — cached unless deps change
COPY package.json package-lock.json ./
COPY client/package.json ./client/package.json
COPY server/package.json ./server/package.json
COPY mock-server/package.json ./mock-server/package.json
COPY e2e/package.json ./e2e/package.json
COPY shared/package.json ./shared/package.json
COPY ui-kit/package.json ./ui-kit/package.json

RUN npm ci --no-audit --no-fund

COPY ui-kit ./ui-kit

WORKDIR /app/ui-kit

ENV CHOKIDAR_USEPOLLING=true

EXPOSE 6006

# Alpine has no xdg-open; Storybook must not try to open a browser
CMD ["npm", "run", "storybook", "--", "--host", "0.0.0.0", "--no-open"]
# CMD ["npm", "run", "build:watch", "--no-open"]
